function deleteChar (pointer s;int16 l) {
  do {
    s[l,int8]:=s[l+1,int8];
    l:=l+1;
    if (s[l,int8]<>0) continue;
  }
}

function insertChar (pointer s;int16 l,int32 c) {
  int16 i=l+length (s+l),j=1;
  
  if (c&0xff00<>0) j:=2;
  if (c&0xff0000<>0) j:=3;
  do {
    s[i+j,int8]:=s[i,int8];
    i:=i-1;
    if (i>=l) continue;
  }
  s[l,int8]:=c;
  if (j>=2) s[l+1,int8]:=shr (c,8);
  if (j=3) s[l+2,int8]:=shr (c,16);
}


function main (int8 code;
  int64 parameters,pointer parameter,pointer enviroment) {
  writeln (system.out,hexadecimal (0x123456789abcdef));
  writeln (system.out,decimal (123456789));
  writeln (system.out,float (1.23456789E0));
  writeln (system.out,float (0.123456789));
  writeln (system.out,float (1000.0));
  writeln (system.out,float (0.0));
  copy (buffer,"Hello World!\n");
  insertChar (buffer,5,'1');
  write (system.out,buffer);
  write (system.out,"Hello World!\n");
}
