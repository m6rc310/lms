}

function LD_IXH_A (;) {
  _IT:=get16 (_A,_IT);
}

function LD_IXL_B (;) {
  _IT:=_IT&0xff00|_B;
}

function LD_IXL_C (;) {
  _IT:=_IT&0xff00|_C;
}

function LD_IXL_D (;) {
  _IT:=_IT&0xff00|_D;
}

function LD_IXL_E (;) {
