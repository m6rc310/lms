*/
  if (halted<>0) break step;
  incpc ();
  addr (1);
  call:=opcode[shl (op,3),pointer];
  call ();
}

function getCBdata (uint8 o;) {
  if (o>4) {
    if (o=5) o:=_L;
    else if (o=7) o:=_A;
    else o:=mem8 (get16 (_H,_L));
  } else if (o<4) {
    if (o=3) o:=_E;
    else if (o=2) o:=_D;
    else if (o=1) o:=_C;
    else o:=_B;
  } else o:=_H;
}

function setCBdata (;uint8 o,uint8 v) {
  if (o>4) {
    if (o=5) _L:=v;
    else if (o=7) _A:=v;
    else setmem8 (get16 (_H,_L),v);
  } else if (o<4) {
    if (o=3) _E:=v;
    else if (o=2) _D:=v;
    else if (o=1) _C:=v;
    else _B:=v;
  } else _H:=v;
}

function addsubA (uint16 r;) {
  _F:=(r&0x80)|(r&0x20)|(r&0x8);
  if (r&0x100<>0) _F:=_F|0x1;
  r:=r&0xff;
  if (r=0) _F:=_F|0x40;
}

function addA (;uint8 v) {
  uint16 r=_A+v;
  
  r:=addsubA (r);
  if (((_A&0xf)+(v&0xf))&0x10<>0) _F:=_F|0x10;
  if (xor (_A,~v)&xor (_A,r)&0x80<>0) _F:=_F|0x4;
  _A:=r;
}

function subA (;uint8 v) {
  uint16 r=_A-v;
  
  r:=addsubA (r);
  if (((_A&0xf)-(v&0xf))&0x10<>0) _F:=_F|0x10;
  if (xor (_A,v)&xor (_A,r)&0x80<>0) _F:=_F|0x4;
  _F:=_F|0x2;
  _A:=r;
}

function adcA (;uint8 v) {
  uint8 c=_F&0x1;
  uint16 r=_A+v+c;
  
  _F:=(r&0x80)|(r&0x20)|(r&0x8);
  if (r&0x100<>0) _F:=_F|0x1;
  r:=r&0xff;
  if (r=0) _F:=_F|0x40;
  if (((_A&0xf)+(v&0xf)+c)&0x10<>0) _F:=_F|0x10;
  if (xor (_A,~v)&xor (_A,r)&0x80<>0) _F:=_F|0x4;
  _A:=r;
}

function sbcA (;uint8 v) {
  uint8 c=_F&0x1;
  uint16 r=_A-v-c;
  
  _F:=(r&0x80)|(r&0x20)|(r&0x8)|0x2;
  if (r&0x100<>0) _F:=_F|0x1;
  r:=r&0xff;
  if (r=0) _F:=_F|0x40;
  if (((_A&0xf)-(v&0xf)-c)&0x10<>0) _F:=_F|0x10;
  if (xor (_A,v)&xor (_A,r)&0x80<>0) _F:=_F|0x4;
  _A:=r;
}

function add16 (uint16 h;uint16 b) {
  uint32 r=h+b;

  _F:=_F&0xc4;
  if (r&0x10000<>0) _F:=_F|0x1;
  if (r&0x2000<>0) _F:=_F|0x20;
  if (r&0x800<>0) _F:=_F|0x8;
  if (((h&0xfff)+(b&0xfff))&0x1000<>0) _F:=_F|0x10;
  h:=r&0xffff;
}

function adc16 (uint16 h;uint16 b) {
  uint8 c=_F&0x1;
  uint32 r=h+b+c;
  
  _F:=shr ((r&0x8000)|(r&0x2000)|(r&0x800),8);
  if (((h&0xfff)+(b&0xfff)+c)&0x1000<>0) _F:=_F|0x10;
  if ((xor (h,~b)&xor (h,r))&0x8000<>0) _F:=_F|0x4;
  if (r&0x10000<>0) _F:=_F|0x1;
  r:=r&0xffff;
  if (r=0) _F:=_F|0x40;
  h:=r;
}

function sbc16 (uint16 h;uint16 b) {
  uint8 c=_F&0x1;
  uint32 r=h-b-c;
  
  _F:=shr ((r&0x8000)|(r&0x2000)|(r&0x800),8)|0x2;
  if (((h&0xfff)-(b&0xfff)-c)&0x1000<>0) _F:=_F|0x10;
  if ((xor (h,b)&xor (h,r))&0x8000<>0) _F:=_F|0x4;
  if (r&0x10000<>0) _F:=_F|0x1;
  r:=r&0xffff;
  if (r=0) _F:=_F|0x40;
  h:=r;
}

function orA (;) {
  _F:=_A&0xa8;
  if (_A=0) _F:=_F|0x40;
  if (parity (_A)<>0) _F:=_F|0x4;
}

function andA (;) {
  orA ();
  _F:=_F|0x10;
}

function arithmeticA (uint8 v;) {
  uint16 r=_A-v;
  
  _F:=(r&0x80)|(v&0x28)|0x2;
  if (r&0x100<>0) _F:=_F|0x1;
  r:=r&0xff;
  if (r=0) _F:=_F|0x40;
  if (((_A&0xf)-(v&0xf))&0x10<>0) _F:=_F|0x10;
  if ((xor (_A,v)&xor (_A,r))&0x80<>0) _F:=_F|0x4;
  v:=r;
}

function inc8 (uint8 r;) {
  _F:=_F&0x1;
  if (r=0x7f) _F:=_F|0x4;
  _F:=_F|((r&0xf)+1)&0x10;
  r:=(r+1)&0xff;
  _F:=_F|(r&0x80);
  if (r=0) _F:=_F|0x40;
  _F:=_F|(r&0x20);
  _F:=_F|(r&0x8);
}

function dec8 (uint8 r;) {
  _F:=_F&0x1|0x2;
  if (r=0x80) _F:=_F|0x4;
  _F:=_F|((r&0xf)-1)&0x10;
  r:=(r-1)&0xff;
  _F:=_F|(r&0x80);
  if (r=0) _F:=_F|0x40;
  _F:=_F|(r&0x20);
  _F:=_F|(r&0x8);
}

function pop (uint16 r;) {
  r:=mem16 (_SP);
  _SP:=_SP+2;
}

function push (;uint16 r) {
  _SP:=_SP-2;
  setmem16 (_SP,r);
}

function interrupt_nmi (;) {
  halted:=0;
  _IFF2:=_IFF1;
  _IFF1:=0;
  push (_PC);
  _PC:=0x66;
}

function interrupt_IFF (;) {
  halted:=0;
  _IFF1:=0;
  _IFF2:=0;
  addr (1);
}

function interrupt_M0 (;uint8 v) {
  if (_IFF1=0) break interrupt_M0;
  interrupt_IFF ();
  call:=opcode[shl (v,3),pointer];
  call ();
}

function interrupt_M1 (;uint8 v) {
  if (_IFF1=0) break interrupt_M1;
  interrupt_IFF ();
  push (_PC);
  _PC:=0x38;
}

function interrupt_M2 (;uint8 v) {
  if (_IFF1=0) break interrupt_M2;
  interrupt_IFF ();
  push (_PC);
  _PC:=mem16 (get16 (_I,v));
}

function interrupt (;uint8 v) {
  if (_IM=0) interrupt_M0 (v);
  else if (_IM=1) interrupt_M1 (v);
  else interrupt_M2 (v);
}

function rlc (uint8 v;) {
  _F:=v&0x80;
  v:=shl (v,1)&0xff;
  if (_F&0x80<>0) {
    _F:=0x1;
    v:=v|0x1;
  }// else _F:=0;
  _F:=_F|(v&0x80)|(v&0x20)|(v&0x8);
  if (v=0) _F:=_F|0x40;
  if (parity (v)<>0) _F:=_F|0x4;
}

function rrc (uint8 v;) {
  _F:=v&0x1;
  v:=shr (v,1)&0xff;
  if (_F&0x1<>0) {
    _F:=0x1;
    v:=v|0x80;
  }// else _F:=0;
  _F:=_F|(v&0x80)|(v&0x20)|(v&0x8);
  if (v=0) _F:=_F|0x40;
  if (parity (v)<>0) _F:=_F|0x4;
}

function rl (uint8 v;) {
  uint8 c=v&0x80;

  v:=shl (v,1)&0xff;
  if (_F&0x1<>0) v:=v|0x1;
  _F:=(v&0x80)|(v&0x20)|(v&0x8);
  if (v=0) _F:=_F|0x40;
  if (parity (v)<>0) _F:=_F|0x4;
  if (c<>0) _F:=_F|0x1;
}

function rr (uint8 v;) {
  uint8 c=v&0x1;

  v:=shr (v,1)&0xff;
  if (_F&0x1<>0) v:=v|0x80;
  _F:=(v&0x80)|(v&0x20)|(v&0x8);
  if (v=0) _F:=_F|0x40;
  if (parity (v)<>0) _F:=_F|0x4;
  _F:=_F|c;
}

function sla (uint8 v;) {
  _F:=v&0x80;
  v:=shl (v,1)&0xff;
  if (_F&0x80<>0) _F:=0x1;
  _F:=_F|(v&0x80)|(v&0x20)|(v&0x8);
  if (v=0) _F:=_F|0x40;
  if (parity (v)<>0) _F:=_F|0x4;
}

function sll (uint8 v;) {
  _F:=v&0x80;
  v:=shl (v,1)&0xff|0x1;
  if (_F&0x80<>0) _F:=0x1;
  _F:=_F|(v&0x80)|(v&0x20)|(v&0x8);
  if (v=0) _F:=_F|0x40;
  if (parity (v)<>0) _F:=_F|0x4;
}

function sra (uint8 v;) {
  _F:=v&0x1;
  v:=shr (v,1)|v&0x80;
  _F:=_F|(v&0x80)|(v&0x20)|(v&0x8);
  if (v=0) _F:=_F|0x40;
  if (parity (v)<>0) _F:=_F|0x4;
}

function srl (uint8 v;) {
  _F:=v&0x1;
  v:=shr (v,1);
  _F:=_F|(v&0x80)|(v&0x20)|(v&0x8);
  if (v=0) _F:=_F|0x40;
  if (parity (v)<>0) _F:=_F|0x4;
}

function rot (uint8 d;uint8 p) {
  if (p=0) d:=rlc (d);
  else if (p=1) d:=rrc (d);
  else if (p=2) d:=rl (d);
  else if (p=3) d:=rr (d);
  else if (p=4) d:=sla (d);
  else if (p=5) d:=sra (d);
  else if (p=6) d:=sll (d);
  else d:=srl (d);
}

function prefixcb (;uint8 o) {
  uint8
    p=shr (o,3)&0x7,
    r=o&0x7,
    d=getCBdata (o&0x7);

  o:=shr (o,6)&0x3;
  if (o=0) d:=rot (d,p);
  else if (o=1) {
    _F:=_F&0x1|0x10|d&0x28;
    d:=d&shl (1,p);
    _F:=_F|d&0x80;
    if (d=0) _F:=_F|0x44;
    if (r=6) _F:=_F&~0x28;
  } else if (o=2) d:=d&~shl (1,p);
  else d:=d|shl (1,p);
  if (o<>1) setCBdata (r,d);

}

function prefix2cb (;uint8 o,uint16 a) {
  uint8
    p=shr (o,3)&0x7,
    r=o&0x7,
    d=mem8 (a);

  o:=shr (o,6)&0x3;
  if (o=0) d:=rot (d,p);
  else if (o=1) {
    d:=d&shl (1,p);
    _F:=_F&0x1|0x10|high (a)&0x28|d&0x80;
    if (d=0) _F:=_F|0x44;
  } else if (o=2) d:=d&~shl (1,p);
  else d:=d|shl (1,p);
  if (o<>1 and r<>6) setCBdata (r,d);
  if (o<>1) setmem8 (a,d);
}

function ldi (;int8 i) {
  uint16
    d=get16 (_D,_E),
    h=get16 (_H,_L),
    v=mem8 (h);
  
  setmem8 (d,v);
  d:=d+i;
  h:=h+i;
  _D:=high (d);
  _E:=low (d);
  _H:=high (h);
  _L:=low (h);
  d:=get16 (_B,_C);
  d:=d-1;
  _B:=high (d);
  _C:=low (d);
  _F:=_F&~0x16;
  if (_B|_C<>0) _F:=_F|0x4;
  else _F:=_F&~0x4;
  if ((v+_A)&0x8<>0) _F:=_F|0x8;
  else _F:=_F&~0x8;
  if ((v+_A)&0x2<>0) _F:=_F|0x20;
  else _F:=_F&~0x20;
//if (_B|_C<>0) _F:=_F&~0x12|0x4;
//else _F:=_F&~0x16;
}

function cpi (;int8 i,uint8 p) {
  uint16 h=get16 (_H,_L);
  uint8
    c=_F&0x1,
    v=arithmeticA (mem8 (h));

  h:=h+i;
  _H:=high (h);
  _L:=low (h);
  h:=get16 (_B,_C);
  h:=h-1;
  _B:=high (h);
  _C:=low (h);
  if (_F&0x10<>0) v:=v-1;
  if (c<>0) _F:=_F|0x1;
  else _F:=_F&0xfe;
  if (v&0x8<>0) _F:=_F|0x8;
  else _F:=_F&~0x8;
  if (v&0x2<>0) _F:=_F|0x20;
  else _F:=_F&~0x20;
  if (_B|_C<>0) {
    _F:=_F|0x4;
    if (p<>0 and _F&0x40=0) addpc (-2);
  } else _F:=_F&~0x4;
}


