}

function SBC_A__IX_d_ (;) {
  uint16 a=_IT+memory[_PC,int8];
  
  sbcA (mem8 (_IT+memi8 (_PC)));
  incpc ();
}

function AND_A_IXH (;) {
  _A:=_A&high (_IT);
  andA ();
}

function AND_A_IXL (;) {
