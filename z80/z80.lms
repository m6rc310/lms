function get16 (uint16 h;uint8 l) {
  h:=shl (h&0xff,8)|l&0xff;
}

function mem8 (uint16 d;) {
  d:=memory[d&0xffff,uint8];
}

function memi8 (int16 d;) {
  d:=memory[d&0xffff,int8];
}

function setmem8 (;uint16 d,uint8 m) {
  memory[d&0xffff,uint8]:=m;
}

function mem16 (uint16 d;) {
  d:=memory[d&0xffff,uint8]|shl (memory[(d+1)&0xffff,uint8],8);
}

function setmem16 (;uint16 d,uint16 m) {
  memory[d&0xffff,uint8]:=m&0xff;
  memory[(d+1)&0xffff,uint8]:=shr (m,8)&0xff;
}

function high (uint16 x;) {
  x:=shr (x,8)&0xff;
}

function low (uint16 x;) {
  x:=x&0xff;
}

function asigr (;int8 i) {
_R:=(_R&0x80)|(i&0x7f);
}

function addr (;int8 i) {
_R:=(_R&0x80)|((_R+i)&0x7f);
}

function incpc (;) {
  _PC:=(_PC+1)&0xffff;
}

function addpc (;uint16 x) {
  _PC:=(_PC+x)&0xffff;
}

function parity (uint8  b;) {
  b:=xor (b,shr (b,4));
  b:=xor (b,shr (b,2));
  b:=xor (b,shr (b,1));
  b:=(~b)&1;
}

function in (uint16 p;) {
  p:=pin (p);
}

function inBC (uint16 p;) {
  p:=pin (get16 (_B,_C));
  _F:=_F&0x1|p&0xa8;
  if (p=0) _F:=_F|0x40;
  if (parity (p)<>0) _F:=_F|0x04;

}

function out (;uint8 p,uint8 v) {
  pout (p,v);
}

function step (;) {
  uint8 op=mem8 (_PC);

/*
if (contador>=1000000) {
if (contador>=1010000) contador:=0;
else {
string.write (system.out,string.decimal (contador));

string.write (system.out," PC=");
string.write (system.out,string.decimal (_PC));
string.write (system.out," o=");
string.write (system.out,string.decimal (memory[_PC,uint8]));
string.write (system.out," p=");
string.write (system.out,string.decimal (memory[_PC+1,uint8]));
string.write (system.out," q=");
string.write (system.out,string.decimal (memory[_PC+2,uint8]));

//string.write (system.out," AF=");
//string.write (system.out,string.decimal ((shl (_A,8)|_F)));
string.write (system.out," A=");
string.write (system.out,string.decimal (_A));
string.write (system.out," BC=");
