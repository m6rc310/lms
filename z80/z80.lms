  incpc ();
}

function IX_CB (;) {
  uint8 a=_IT+memi8 (_PC);

  incpc ();
  prefix2cb (mem8 (_PC),a);
  incpc ();
}

function POP_IX (;) {
  _IT:=pop (0);
}

function EX__SP__IX (;) {
  uint16 x=_IT;
  
  _IT:=mem16 (_SP);
  setmem16 (_SP,x);
}

function PUSH_IX (;) {
  push (_IT);
}

function JP__IX_ (;) {
  _PC:=_IT;
}

function LD_SP_IX (;) {
  _SP:=_IT;
}


function defaultIXIY (;uint8 o) {
  _R:=addr (-1);
  call:=opcode[shl (o,3),pointer];
  call ();  
}

function opIXIY (;) {
  uint8 op=memory[_PC,uint8];
  
  incpc ();
  addr (1);
  if (op<112) {
    if (op<54) {
      if (op<34) {
        
        if (op=33) LD_IX_nn ();
        else if (op=25) ADD_IX_DE ();
        else if (op=9) ADD_IX_BC ();
        else defaultIXIY (op);
      
      } else if (op=34) LD__nn__IX ();
      else {
        if (op<44) {
          if (op<38) {
            
            if (op=35) INC_IX ();
            else if (op=36) INC_IXH ();
            else DEC_IXH ();
          
          } else if (op=38) LD_IXH_n ();
          else {
            
            if (op=41) ADD_IX_IX ();
            else if (op=42) LD_IX__nn_ ();
            else if (op=43) DEC_IX ();
            else defaultIXIY (op);
          }
        } else if (op=44) INC_IXL ();
        else {
          if (op<52) {
            
            if (op=45) DEC_IXL ();
            else if (op=46) LD_IXL_n ();
            else defaultIXIY (op);
          
          } else if (op=52) INC__IX_d_ ();   
          else DEC__IX_d_ ();
        }
      }
    } else if (op=54) LD__IX_d__n ();
    else {
      if (op<85) {
        if (op<77) {
          
          if (op=76) LD_C_IXH ();
          else if (op=70) LD_B__IX_d_ ();
          else if (op=69) LD_B_IXL ();
          else if (op=68) LD_B_IXH ();
          else if (op=57) ADD_IX_SP ();
          else defaultIXIY (op);
          
        } else if (op=77) LD_C_IXL ();
        else {
          
          if (op=78) LD_C__IX_d_ ();
          else if (op=84) LD_D_IXH ();
          else defaultIXIY (op);
          
        }
      } else if (op=85) LD_D_IXL ();
      else {
        if (op<99) {
          if (op<93) {
            
            if (op=92) LD_E_IXH ();
            else if (op=86) LD_D__IX_d_ ();
            else defaultIXIY (op);
            
          } else if (op=93) LD_E_IXL ();
          else {
            
            if (op=94) LD_E__IX_d_ ();
            else if (op=96) LD_IXH_B ();
            else if (op=97) LD_IXH_C ();
            else if (op=98) LD_IXH_D ();
            else defaultIXIY (op);
            
          }
        } else if (op=99) LD_IXH_E ();
        else {
          if (op<105) {
            
            if (op=100) NOP ();         //LD_IXH_IXH ();
            else if (op=101) LD_IXH_IXL ();
            else if (op=102) LD_H__IX_d_ ();
            else if (op=103) LD_IXH_A ();
            else LD_IXL_B ();
            
          } else if (op=105) LD_IXL_C ();
          else {
            
            if (op=106) LD_IXL_D ();
            else if (op=107) LD_IXL_E ();
            else if (op=108) LD_IXL_IXH ();
            else if (op=109) NOP ();    //LD_IXL_IXL ();
            else if (op=110) LD_L__IX_d_ ();
            else LD_IXL_A ();
          }
        }
      }
    }
  } else if (op=112) LD__IX_d__B ();
  else {
    if (op<181) {
      if (op<142) {
        if (op<119) {
          
          if (op=113) LD__IX_d__C ();
          else if (op=114) LD__IX_d__D ();
          else if (op=115) LD__IX_d__E ();
          else if (op=116) LD__IX_d__H ();
          else if (op=117) LD__IX_d__L ();
          else defaultIXIY (op);
          
        } else if (op=119) LD__IX_d__A ();
        else {
          if (op<126) {
            
            if (op=125) LD_A_IXL ();
            else if (op=124) LD_A_IXH ();
            else defaultIXIY (op);
            
          } else if (op=126) LD_A__IX_d_ ();
          else {
            
            if (op=132) ADD_A_IXH ();
            else if (op=133) ADD_A_IXL ();
            else if (op=134) ADD_A__IX_d_ ();
            else if (op=140) ADC_A_IXH ();
            else if (op=141) ADC_A_IXL ();
            else defaultIXIY (op);
            
          }
        }
      } else if (op=142) ADC_A__IX_d_ ();
      else {
        if (op<166) {
          
          if (op=165) AND_A_IXL ();
          else if (op=164) AND_A_IXH ();
          else if (op=158) SBC_A__IX_d_ ();
          else if (op=157) SBC_A_IXL ();
          else if (op=156) SBC_A_IXH ();
          else if (op=150) SUB_A__IX_d_ ();
          else if (op=149) SUB_A_IXL ();
          else if (op=148) SUB_A_IXH ();
          else defaultIXIY (op);
          
        } else if (op=166) AND_A__IX_d_ ();
        else {
          
          if (op=180) OR_A_IXH ();
          else if (op=174) XOR_A__IX_d_ ();
          else if (op=173) XOR_A_IXL ();
          else if (op=172) XOR_A_IXH ();
          else defaultIXIY (op);
        }
      }
    } else if (op=181) OR_A_IXL ();
    else {
      if (op<203) {
        
        if (op=190) CP_A__IX_d_ ();
        else if (op=189) CP_A_IXL ();
        else if (op=188) CP_A_IXH ();
        else if (op=182) OR_A__IX_d_ ();
        else defaultIXIY (op);
        
    } else if (op=203) IX_CB ();
      else {

        if (op=225) POP_IX ();
        else if (op=227) EX__SP__IX ();
        else if (op=229) PUSH_IX ();
        else if (op=233) JP__IX_ ();
        else if (op=249) LD_SP_IX ();
        else defaultIXIY (op);

      }
    }
  }
}

function initZ80 (;) {
  _PC:=0;_IX:=0;_IY:=0;
//  _SP:=0xffff;
_SP:=0;
//  _A:=0xff;_F:=0xff;
_A:=0;_F:=0;
  _B:=0;_C:=0;
  _D:=0;_E:=0;
  _H:=0;_L:=0;

  __A:=0;__F:=0;
  __B:=0;__C:=0;
  __D:=0;__E:=0;
  __H:=0;__L:=0;
  
  _I:=0;_R:=0;
  _IM:=0;
  _IFF1:=0;_IFF2:=0;
  halted:=0;
}

function intest (uint16 p;) {
  p:=0;
}

function outtest (;uint16 p,uint8 v) {
  uint16 a;

  if(v=1) {
    string.buffer[1,uint8]:=0;
    if (_C=2) {
      string.buffer[uint8]:=_E;
      string.write (system.out,string.buffer);
    } else if (_C=9) {
      a:=get16 (_D,_E);
      do {
        if (mem8 (a)='$') break;
        string.buffer[uint8]:=mem8 (a);
        string.write (system.out,string.buffer);
        a:=a+1;
        continue;
      }
    }
  }
}


function main (int8 code;
    int64 parameters,pointer parameter,pointer enviroment) {
  int64 file,n;
  
  string.hexDigit:=4;
  memory:=system.memory (0x10000);
  file:=system.open ("zexdoc.com",system.O_RDONLY,0);
  n:=system.seek (file,0,system.SEEK_END);
  system.seek (file,0,system.SEEK_SET);
  system.read (file,memory+0x100,n);
  pin:=intest;
  pout:=outtest;
  
  memory[5,uint8]:=0x3e;
  memory[6,uint8]:=0x01;
  memory[7,uint8]:=0xd3;
  memory[8,uint8]:=0x00;
  memory[9,uint8]:=0xc9;

  initZ80 ();
  _PC:=0x100;
  do {
/*
string.write (system.out,"PC=");
string.write (system.out,string.hexadecimal (_PC));
string.write (system.out," o=");
string.write (system.out,string.decimal (memory[_PC,uint8]));
string.write (system.out," p=");
string.write (system.out,string.decimal (memory[_PC+1,uint8]));

string.write (system.out," AF=");
string.write (system.out,string.hexadecimal ((shl (_A,8)|_F)));
string.write (system.out," BC=");
string.write (system.out,string.hexadecimal (shl (_B,8)|_C));
string.write (system.out," DE=");
string.write (system.out,string.hexadecimal (shl (_D,8)|_E));
string.write (system.out," HL=");
string.write (system.out,string.hexadecimal (shl (_H,8)|_L));

string.write (system.out," SP=");
string.write (system.out,string.hexadecimal (_SP));
string.write (system.out,"\n");

string.write (system.out," (0x0103)=");
string.write (system.out,string.hexadecimal (memory[0x0103,uint8]));

string.write (system.out,"\n");
*/
    step ();

    if (_PC=0) break;
    continue;
  }
  string.write (system.out,"\n");
}
