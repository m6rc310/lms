  _F:=(_F&0x1)|(_A&0xa8);
  if (_A=0) _F:=_F|0x40;
  if (parity (_A)<>0) _F:=_F|0x4;
}

function IN__C_ (;) {
  inBC (0);
}

function OUT__C__0 (;) {
  out (_C,0);
}

function SBC_HL_SP (;) {
  uint16 r=sbc16 (get16 (_H,_L),_SP);
  
  _H:=high (r);
  _L:=low (r);
}

function LD__nn__SP (;) {
  setmem16 (mem16 (_PC),_SP);
  addpc (2);
}

