}

function LD_IXL_IXH (;) {
  _IT:=_IT&0xff00|shr (_IT,8);
}

//function LD_IXL_IXL (;) {}

function LD_L__IX_d_ (;) {
  _L:=mem8 (_IT+memi8 (_PC));
  incpc ();
}

function LD_IXL_A (;) {
