function DA_A (;) {
  uint8 i=0,c=_F&0x1;
  
  if (_F&0x10<>0 or _A&0xf>9) i:=0x6;
  if (c<>0 or _A>0x99) {
    i:=i|0x60;
    _F:=_F|0x1;
  }
  if (_F&0x2<>0) {
    if (_F&0x10<>0 and _A&0xf<0x6) _F:=_F|0x10;
    else _F:=_F&~0x10;
    _A:=_A-i;
  } else {
    if (_A&0xf>9) _F:=_F|0x10;
    else _F:=_F&~0x10;
    _A:=_A+i;
  }
  if (parity (_A)<>0) _F:=_F|0x4;
  else _F:=_F&~0x4;
  _F:=(_F&~0xe8)|_A&0xa8;
  if (_A=0) _F:=_F|0x40;
}

function JRZ_d (;) {  
  if (_F&0x40<>0) addpc (memi8 (_PC));
  incpc ();
