function LDI (;) {
  ldi (1);
}

function CPI (;) {
  cpi (1,0);
}

function INI (;) {
  uint16 h=get16 (_H,_L);

  setmem8 (h,in (_C));
  _B:=_B-1;
  h:=h+1;
  _H:=high (h);
  _L:=low (h);
  _F:=_F|0x2;
  if (_B=0) _F:=_F|0x40;
  else _F:=_F&~0x40;
}

function OUTI (;) {
  uint16 h=get16 (_H,_L);

  _B:=_B-1;
  out (_C,mem8 (h));
  h:=h+1;
  _H:=high (h);
  _L:=low (h);
  _F:=_F|0x2;
  if (_B=0) _F:=_F|0x40;
  else _F:=_F&~0x40;
}

