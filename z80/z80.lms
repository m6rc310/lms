  _F:=_F|0x42;
  if (_B<>0) addpc (-2);
}

function ADD_IX_BC (;) {    //opcode prefix index IX,IY
  _IT:=add16 (_IT,get16 (_B,_C));
}

function ADD_IX_DE (;) {
  _IT:=add16 (_IT,get16 (_D,_E));
}

function LD_IX_nn (;) {
  _IT:=mem16 (_PC);
  addpc (2);
}

function LD__nn__IX (;) {
  setmem16 (mem16 (_PC),_IT);
  addpc (2);
}

function INC_IX (;) {
  _IT:=_IT+1;
}

function INC_IXH (;) {
  _IT:=get16 (inc8 (high (_IT)),_IT);
}

function DEC_IXH (;) {
  _IT:=get16 (dec8 (high (_IT)),_IT);
}

function LD_IXH_n (;) {
  _IT:=get16 (mem8 (_PC),_IT);
  incpc ();
}

function ADD_IX_IX (;) {
  _IT:=add16 (_IT,_IT);
}

function LD_IX__nn_ (;) {
  _IT:=mem16 (mem16 (_PC));
  addpc (2);
}

function DEC_IX (;) {
  _IT:=_IT-1;
}

function INC_IXL (;) {
  _IT:=_IT&0xff00|(inc8 (_IT)&0xff);
}

function DEC_IXL (;) {
  _IT:=_IT&0xff00|(dec8 (_IT)&0xff);
}

function LD_IXL_n (;) {
  _IT:=_IT&0xff00|mem8 (_PC);
  incpc ();
}

function INC__IX_d_ (;) {
  uint16 a=_IT+memi8 (_PC);
  
  incpc ();
  setmem8 (a,inc8 (mem8 (a)));
}

function DEC__IX_d_ (;) {
  uint16 a=_IT+memi8 (_PC);
  
  incpc ();
  setmem8 (a,dec8 (mem8 (a)));
}

function LD__IX_d__n (;) {
  uint16 a=_IT+memi8 (_PC);
  
  incpc ();
  setmem8 (a,mem8 (_PC));
  incpc ();
}

function ADD_IX_SP (;) {
  _IT:=add16 (_IT,_SP);
}


function LD_B_IXH (;) {
  _B:=high (_IT);
}

function LD_B_IXL (;) {
