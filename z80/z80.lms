function ED (;) {       // prefix
  uint8 op=memory[_PC,uint8];

  incpc ();
  if (64<=op and op<=126)
    call:=op1de[shl (op-64,3),pointer];
  else if (160<=op and op<=187)
    call:=op2de[shl (op-160,3),pointer];
  else call:=NOP;
  call ();
}

